.ai-page {
  padding-bottom: calc(300rpx + var(--safe-bottom));
}

.context-card {
  padding: 30rpx;
  background:
    radial-gradient(circle at 86% 18%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(150deg, rgba(210, 230, 255, 0.54), rgba(235, 229, 255, 0.42) 58%, rgba(255, 220, 154, 0.38));
}

.context-card .section-subtitle {
  color: var(--color-muted);
}

.context-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.context-label {
  color: #1f5fd1;
  font-size: 23rpx;
  font-weight: 700;
}

.context-title {
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 760;
}

.new-session {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 255, 0.1);
  color: #1f5fd1;
  font-size: 23rpx;
  font-weight: 700;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 26rpx;
  padding-bottom: 260rpx;
}

.empty-guide {
  padding: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(248, 251, 255, 0.34));
}

.empty-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 780;
  line-height: 1.3;
}

.empty-copy {
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.empty-prompts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.empty-chip {
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 255, 0.08);
  color: #315a9d;
  font-size: 23rpx;
  font-weight: 650;
}

.state-text {
  color: var(--color-muted);
  font-size: 26rpx;
  padding: 12rpx 4rpx;
}

.state-text.error {
  color: #be123c;
}

.message {
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.58;
}

.user-message {
  align-self: flex-end;
  max-width: 520rpx;
  padding: 18rpx 22rpx;
  border-radius: 32rpx 32rpx 10rpx 32rpx;
  background: rgba(255, 255, 255, 0.7);
  color: var(--color-text);
  white-space: pre-wrap;
  box-shadow: 0 12rpx 34rpx rgba(44, 54, 82, 0.08);
}

.ai-message {
  padding: 26rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(247, 250, 255, 0.42));
}

.answer-copy {
  color: #334155;
  white-space: pre-wrap;
  font-size: 26rpx;
  line-height: 1.68;
}

.typing {
  color: var(--color-muted);
}

.ai-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  align-items: stretch;
  margin-top: 24rpx;
}

.reference-card {
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(31, 111, 255, 0.08);
  overflow: hidden;
}

.reference-title {
  color: #1d4ed8;
  font-size: 23rpx;
  font-weight: 740;
}

.reference-item {
  margin-top: 10rpx;
  color: #334155;
  font-size: 23rpx;
  line-height: 1.45;
}

.review-action {
  justify-self: start;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(25, 169, 116, 0.12);
  color: #047857;
  font-size: 23rpx;
  font-weight: 760;
  white-space: nowrap;
}

.typing-line {
  width: 180rpx;
  height: 8rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f6fff, #ffbc5d, #1f6fff);
  background-size: 200% 100%;
  animation: shimmer 1.2s ease-in-out infinite;
}

@keyframes shimmer {
  from {
    background-position: 0 0;
  }
  to {
    background-position: 200% 0;
  }
}

.chat-composer {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(18rpx + var(--safe-bottom));
  padding: 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.66);
  backdrop-filter: blur(34rpx) saturate(155%);
  -webkit-backdrop-filter: blur(34rpx) saturate(155%);
  z-index: 20;
  box-shadow: 0 -10rpx 38rpx rgba(50, 70, 110, 0.12);
}

.chip-scroll {
  width: 100%;
  white-space: nowrap;
}

.nowrap {
  flex-wrap: nowrap;
  display: inline-flex;
}

.nowrap .chip {
  flex: 0 0 auto;
  background: rgba(31, 111, 255, 0.08);
  color: #315a9d;
  border: 1rpx solid rgba(255, 255, 255, 0.64);
}

.input-row {
  display: grid;
  grid-template-columns: 88rpx 1fr 104rpx;
  gap: 12rpx;
  margin-top: 18rpx;
}

.voice-hint {
  margin-top: 14rpx;
  padding: 0 4rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-word;
}

.voice-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  border-radius: 24rpx;
  background: rgba(25, 169, 116, 0.1);
  color: #047857;
  font-size: 23rpx;
  font-weight: 760;
  transition: all 0.2s ease-in-out;
}

.voice-recording {
  background: linear-gradient(135deg, #ef4d6f, #ff8a5c);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(239, 68, 68, 0.22);
}

.voice-disabled {
  opacity: 0.45;
}

.input-real {
  min-width: 0;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(248, 251, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  color: var(--color-text);
  font-size: 25rpx;
}

.send-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #1f6fff;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 740;
}

.send-disabled {
  opacity: 0.4;
}
