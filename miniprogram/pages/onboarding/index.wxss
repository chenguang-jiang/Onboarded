.onboarding-page {
  position: relative;
  overflow: hidden;
  padding-bottom: 56rpx;
}

.orbital-bg {
  position: absolute;
  top: 8rpx;
  right: -120rpx;
  width: 460rpx;
  height: 460rpx;
  border: 2rpx solid rgba(31, 111, 255, 0.08);
  border-radius: 50%;
  box-shadow:
    inset 0 0 90rpx rgba(255, 255, 255, 0.36),
    0 28rpx 90rpx rgba(31, 111, 255, 0.14);
}

.hero {
  position: relative;
  padding: 42rpx 34rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(255, 255, 255, 0.78), transparent 30%),
    linear-gradient(155deg, rgba(232, 243, 255, 0.96), rgba(240, 237, 255, 0.9) 52%, rgba(255, 235, 194, 0.88));
}

.hero-kicker {
  color: #1f5fd1;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 18rpx;
  color: var(--color-text);
  font-size: 64rpx;
  font-weight: 850;
  line-height: 1;
}

.hero-copy {
  margin-top: 22rpx;
  max-width: 560rpx;
  color: var(--color-muted);
  font-size: 27rpx;
  line-height: 1.55;
}

.setup-panel {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 34rpx;
  padding: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(247, 250, 255, 0.74));
}

.field-label {
  margin-bottom: 14rpx;
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 760;
}

.picker-control {
  min-height: 92rpx;
  box-sizing: border-box;
  padding: 27rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 700;
}

.target-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
}

.target-chip {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.68);
  color: var(--color-muted);
  font-size: 28rpx;
  font-weight: 760;
}

.target-chip-active {
  border-color: rgba(31, 111, 255, 0.44);
  background: linear-gradient(135deg, rgba(31, 111, 255, 0.96), rgba(116, 173, 255, 0.96));
  box-shadow: var(--shadow-soft);
  color: #ffffff;
}

.error-banner {
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(244, 63, 94, 0.1);
  color: #be123c;
  font-size: 24rpx;
  line-height: 1.4;
}

.submit-button {
  width: 100%;
  margin: 8rpx 0 0;
  border: 0;
}
