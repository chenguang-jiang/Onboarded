.answer-page {
  padding-bottom: calc(180rpx + var(--safe-bottom));
}

.state-card {
  padding: 40rpx;
  color: var(--color-muted);
  font-size: 28rpx;
  line-height: 1.5;
}

.state-card.error {
  color: #be123c;
}

.knowledge-flip {
  height: 280rpx;
  perspective: 1200rpx;
  margin-bottom: 24rpx;
}

.flip-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.42s ease-in-out;
  transform-style: preserve-3d;
}

.knowledge-flip.is-flipped .flip-inner {
  transform: rotateY(180deg);
}

.knowledge-face {
  position: absolute;
  inset: 0;
  padding: 30rpx;
  backface-visibility: hidden;
}

.knowledge-front {
  background:
    radial-gradient(circle at 88% 16%, rgba(255, 255, 255, 0.78), transparent 30%),
    linear-gradient(155deg, rgba(232, 243, 255, 0.96), rgba(238, 236, 255, 0.9) 55%, rgba(255, 235, 194, 0.88));
}

.knowledge-back {
  transform: rotateY(180deg);
  background:
    linear-gradient(150deg, rgba(255, 255, 255, 0.88), rgba(255, 245, 232, 0.76));
}

.knowledge-back .knowledge-label {
  color: var(--color-primary);
}

.knowledge-back .trap-copy {
  color: #334155;
}

.knowledge-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.knowledge-label {
  color: #1f5fd1;
  font-size: 23rpx;
  font-weight: 760;
}

.knowledge-title {
  margin-top: 10rpx;
  color: var(--color-text);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.flip-trigger {
  flex: 0 0 auto;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 255, 0.1);
  color: #1f5fd1;
  font-size: 22rpx;
  font-weight: 760;
}

.knowledge-summary,
.trap-copy {
  margin-top: 24rpx;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.62;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-card {
  padding: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(247, 250, 255, 0.74));
}

.question-stem {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: 740;
  line-height: 1.4;
}

.option-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 22rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  background: rgba(255, 255, 255, 0.72);
  transition: background 0.24s ease-in-out, border-color 0.24s ease-in-out, transform 0.24s ease-in-out;
}

.option-key {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(31, 111, 255, 0.1);
  color: #1f5fd1;
  font-size: 26rpx;
  font-weight: 700;
}

.option-text {
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.5;
}

.option-row.selected {
  border-color: rgba(31, 111, 255, 0.28);
  background: rgba(31, 111, 255, 0.08);
  transform: translateY(-2rpx);
}

.option-row.selected .option-key {
  background: #1f6fff;
  color: #ffffff;
}

.option-row.correct,
.option-row.is-correct {
  border-color: rgba(25, 169, 116, 0.28);
  background: linear-gradient(135deg, rgba(25, 169, 116, 0.18), rgba(124, 221, 184, 0.08));
  box-shadow: 0 14rpx 32rpx rgba(25, 169, 116, 0.12);
}

.option-row.correct .option-key,
.option-row.is-correct .option-key {
  background: var(--color-success);
  color: #ffffff;
}

.option-row.wrong,
.option-row.is-wrong {
  border-color: rgba(244, 63, 94, 0.18);
  background: rgba(244, 63, 94, 0.07);
}

.option-row.wrong .option-key,
.option-row.is-wrong .option-key {
  background: var(--color-danger);
  color: #ffffff;
}

.result-card {
  margin-top: 24rpx;
  padding: 32rpx;
  animation: analysisIn 0.28s ease-in-out both;
}

.result-correct {
  background: linear-gradient(160deg, rgba(235, 255, 246, 0.88), rgba(255, 255, 255, 0.76));
}

.result-wrong {
  background: linear-gradient(160deg, rgba(255, 241, 244, 0.9), rgba(255, 255, 255, 0.76));
}

@keyframes analysisIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-banner {
  font-size: 30rpx;
  font-weight: 750;
}

.result-banner.banner-correct {
  color: var(--color-success);
}

.result-banner.banner-wrong {
  color: var(--color-danger);
}

.result-section {
  margin-top: 22rpx;
}

.result-label {
  color: var(--color-muted);
  font-size: 23rpx;
  font-weight: 700;
}

.result-explanation {
  margin-top: 10rpx;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.6;
}

.result-actions {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.result-actions .action {
  min-height: 84rpx;
  font-size: 27rpx;
}

.submit-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(112rpx + var(--safe-bottom));
  z-index: 8;
}

.submit-button.disabled {
  opacity: 0.5;
}
