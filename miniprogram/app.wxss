:root,
page {
  --color-bg: #f7faff;
  --color-bg-blue: #eef5ff;
  --color-bg-purple: #f3efff;
  --color-bg-pink: #fff0f6;
  --color-primary: #1f6fff;
  --color-success: #19a974;
  --color-warning: #f6b94b;
  --color-danger: #ef4d6f;
  --color-text: #162033;
  --color-muted: #667489;
  --color-line: rgba(255, 255, 255, 0.66);
  --radius-card: 34rpx;
  --radius-control: 24rpx;
  --shadow-card: 0 26rpx 72rpx rgba(50, 70, 110, 0.14);
  --shadow-soft: 0 14rpx 34rpx rgba(31, 111, 255, 0.16);
  --space-page-x: 32rpx;
  --safe-bottom: env(safe-area-inset-bottom);
  min-height: 100%;
  color: var(--color-text);
  background:
    radial-gradient(circle at 16% 8%, rgba(111, 184, 255, 0.42), transparent 30vh),
    radial-gradient(circle at 88% 16%, rgba(255, 194, 104, 0.36), transparent 30vh),
    radial-gradient(circle at 52% 54%, rgba(238, 183, 220, 0.28), transparent 34vh),
    linear-gradient(180deg, #f8fbff 0, #edf5ff 48vh, #fff5fb 100vh),
    var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "MiSans", "Helvetica Neue", Arial, sans-serif;
  letter-spacing: 0;
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 34rpx var(--space-page-x) calc(54rpx + var(--safe-bottom));
}

.glass-card {
  box-sizing: border-box;
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-card);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.38));
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(36rpx) saturate(150%);
  -webkit-backdrop-filter: blur(36rpx) saturate(150%);
  box-shadow:
    inset 0 2rpx 2rpx rgba(255, 255, 255, 0.72),
    inset 0 -1rpx 0 rgba(255, 255, 255, 0.32),
    var(--shadow-card);
  overflow: hidden;
}

.section-title {
  margin: 0;
  color: var(--color-text);
  font-size: 35rpx;
  font-weight: 780;
  line-height: 1.24;
}

.section-subtitle {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.metric-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.metric-card {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  background: rgba(255, 255, 255, 0.34);
  backdrop-filter: blur(28rpx) saturate(140%);
  -webkit-backdrop-filter: blur(28rpx) saturate(140%);
  box-shadow: inset 0 2rpx 2rpx rgba(255, 255, 255, 0.62);
}

.metric-value {
  display: block;
  color: var(--color-text);
  font-size: 42rpx;
  font-weight: 750;
  line-height: 1;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.3;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1f6fff, #6aa6ff);
  box-shadow: 0 20rpx 44rpx rgba(31, 111, 255, 0.28);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 650;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.5);
  color: #315a9d;
  font-size: 23rpx;
  line-height: 1.2;
}
